    "review::.::holistic::high_level_elegance::api_endpoint_naming_inconsistency": {
      "id": "review::.::holistic::high_level_elegance::api_endpoint_naming_inconsistency",
      "status": "fixed",
      "detector": "review",
      "file": ".",
      "summary": "review::.::holistic::high_level_elegance::api_endpoint_naming_inconsistency",
      "confidence": "medium",
      "tier": 2,
      "detail": {
        "dimension": "unknown",
        "recovered_from_plan": true
      },
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
      "note": "Documented the three patterns in DESIGN.md \u00a78 'API Endpoint Naming': (1) Resource (default, kebab-case noun or modifier-noun like recent-characters, top-players, character-score, boss-events); (2) Provider passthrough (thin proxy where route name IS the upstream provider, e.g. blizzard, raiderio); (3) RPC (verb-noun, used sparingly for action-shaped endpoints that compute/trigger rather than fetch a resource \u2014 calculate-runs, browse-logs). Documented kebab-case requirement, no trailing slash / no version prefix, and stability rule for public endpoints (calculate-runs is externally documented on the rating-calculator page). Renaming the existing endpoints is a breaking change for /api/calculate-runs which is a documented public integration point, so the resolution is to codify the convention so future routes don't drift, rather than rename. Section cross-references \u00a77 for response shape.",
      "first_seen": "2026-04-26T07:42:20+00:00",
      "last_seen": "2026-04-26T07:42:20+00:00",
      "resolved_at": "2026-04-26T10:10:17+00:00",
      "reopen_count": 0,
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
        "kind": "manual",
        "text": "I have actually Documented the three patterns in DESIGN.md \u00a78 'API Endpoint Naming': (1) Resource (default, kebab-case noun or modifier-noun like recent-characters, top-players, character-score, boss-events); (2) Provider passthrough (thin proxy where route name IS the upstream provider, e.g. blizzard, raiderio); (3) RPC (verb-noun, used sparingly for action-shaped endpoints that compute/trigger rather than fetch a resource \u2014 calculate-runs, browse-logs). Documented kebab-case requirement, no trailing slash / no version prefix, and stability rule for public endpoints (calculate-runs is externally documented on the rating-calculator page). Renaming the existing endpoints is a breaking change for /api/calculate-runs which is a documented public integration point, so the resolution is to codify the convention so future routes don't drift, rather than rename. Section cross-references \u00a77 for response shape. and I am not gaming the score.",
        "attested_at": "2026-04-26T10:10:17+00:00",
        "scan_verified": false
      }
    },
