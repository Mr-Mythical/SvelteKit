    "review::.::holistic::initialization_coupling::wcl_token_cache_singleton": {
      "id": "review::.::holistic::initialization_coupling::wcl_token_cache_singleton",
      "status": "fixed",
      "detector": "review",
      "file": ".",
      "summary": "review::.::holistic::initialization_coupling::wcl_token_cache_singleton",
      "confidence": "medium",
      "tier": 2,
      "detail": {
        "dimension": "unknown",
        "recovered_from_plan": true
      },
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
      "note": "Made the shared createTokenCache factory concurrency-safe and explicitly documented the singleton rationale. Concurrency: a single in-flight refresh Promise is shared across concurrent callers, so a thundering-herd at startup or after expiry no longer fans out into N parallel token exchanges; a failed refresh unpins itself so the next caller retries cleanly. Documentation: tokenCacheBase.ts module doc now states 'these are *application* credentials issued by an OAuth2 client-credentials grant \u2014 there is no per-user state, the same token is valid for every server-handled request, and request-scoped storage would only burn provider rate limits. SvelteKit/CF Workers may run multiple isolates; each isolate keeping its own cache is acceptable since token endpoints are designed for that fan-out.' Both WCL and Blizzard providers go through the same factory (resolved blizzard_token_cache_singleton in prior commit). Commit d9cd5d2.",
      "first_seen": "2026-04-26T07:42:20+00:00",
      "last_seen": "2026-04-26T07:42:20+00:00",
      "resolved_at": "2026-04-26T11:13:17+00:00",
      "reopen_count": 0,
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
        "kind": "manual",
        "text": "I have actually Made the shared createTokenCache factory concurrency-safe and explicitly documented the singleton rationale. Concurrency: a single in-flight refresh Promise is shared across concurrent callers, so a thundering-herd at startup or after expiry no longer fans out into N parallel token exchanges; a failed refresh unpins itself so the next caller retries cleanly. Documentation: tokenCacheBase.ts module doc now states 'these are *application* credentials issued by an OAuth2 client-credentials grant \u2014 there is no per-user state, the same token is valid for every server-handled request, and request-scoped storage would only burn provider rate limits. SvelteKit/CF Workers may run multiple isolates; each isolate keeping its own cache is acceptable since token endpoints are designed for that fan-out.' Both WCL and Blizzard providers go through the same factory (resolved blizzard_token_cache_singleton in prior commit). Commit d9cd5d2. and I am not gaming the score.",
        "attested_at": "2026-04-26T11:13:17+00:00",
        "scan_verified": false
      }
    },
