      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "/api/character-score returns the success body shape with HTTP 400, breaking the codebase-wide `{error:string}` error contract",
      "detail": {
        "holistic": true,
