    "review::.::holistic::test_strategy::copy_and_classname_assertions_in_component_tests": {
      "id": "review::.::holistic::test_strategy::copy_and_classname_assertions_in_component_tests",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "Page and ContentShowcase tests assert exact marketing copy and Tailwind class fragments \u2014 high churn, low signal",
      "detail": {
        "holistic": true,
        "dimension": "test_strategy",
        "related_files": [
          "src/components/__tests__/page.test.ts",
          "src/components/__tests__/contentShowcase.test.ts"
        ],
        "evidence": [
          "page.test.ts: `expect(screen.getByText('Master World of Warcraft with Mr. Mythical'))` and `'Premium WoW Tools for Competitive Players'` \u2014 verbatim hero copy",
          "contentShowcase.test.ts: `expect(link?.className).toContain('hover:scale-105')`, `'transition-transform'`, `image?.className.toContain('block')` \u2014 pure styling assertions",
          "contentShowcase.test.ts wraps every test in `vi.useFakeTimers()` despite not advancing time in any assertion"
        ],
        "suggestion": "Replace text-equality assertions with stable role/landmark queries (e.g. `getByRole('heading', { level: 1 })`); drop className assertions entirely (CSS regressions belong to visual review, not unit tests). Remove the fake-timer setup from contentShowcase tests since no timer is actually exercised.",
        "reasoning": "",
        "summary_hash": "2afce917"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-04-26T14:29:22+00:00",
