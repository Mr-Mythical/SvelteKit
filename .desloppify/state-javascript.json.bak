    "review::.::holistic::high_level_elegance::dual_component_homes_undocumented": {
      "id": "review::.::holistic::high_level_elegance::dual_component_homes_undocumented",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "src/components/ and src/lib/components/ui/ are two component roots with no documented dividing line",
      "detail": {
        "holistic": true,
        "dimension": "high_level_elegance",
        "related_files": [
          "src/components/seo.svelte",
          "src/components/layout/footer.svelte",
          "src/lib/components/ui/button/button.svelte"
        ],
        "evidence": [
          "src/components/ holds feature components (charts/, calculator/, combobox/, layout/, raid/, skeletons/, seo.svelte, authButton.svelte).",
          "src/lib/components/ui/ holds shadcn primitives (accordion/, badge/, button/, ..., textarea/) and nothing else.",
          "SvelteKit convention is to keep components under $lib; src/components/ deviates without explanation.",
          "Concrete consequence: feature components routinely cross the boundary via `import Button from '$lib/components/ui/button/button.svelte'` (e.g. components/authButton.svelte, components/layout/header.svelte, components/charts/damageChart.svelte). The split works in practice but a new engineer cannot derive the rule."
        ],
        "suggestion": "Either document the rule in README ('feature components live in src/components/<feature>/, low-level UI primitives live in $lib/components/ui/ \u2014 shadcn import path is preserved') or move src/components/ under $lib/components/feature/ to match the convention. Do not introduce a barrel.",
        "reasoning": "",
        "summary_hash": "3d9bac24"
