      "origin": "review_import",
      "lang": "typescript",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::test_strategy::barrel_export_mirror_test": {
      "id": "review::.::holistic::test_strategy::barrel_export_mirror_test",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "formIndex.test.ts only verifies a barrel module re-exports its own symbols",
      "detail": {
        "holistic": true,
        "dimension": "test_strategy",
        "related_files": [
          "src/lib/__tests__/formIndex.test.ts",
          "src/lib/components/ui/form/index.ts"
        ],
        "evidence": [
          "All assertions are `expect(FormExports).toHaveProperty('Field')` and `expect(FormExports.FormField).toBe(FormExports.Field)`",
          "Test couples 1:1 to the index file content; no behavior is exercised"
        ],
        "suggestion": "Delete formIndex.test.ts. TypeScript already enforces export presence at build time; if alias parity matters, encode it as a type-level test (`type _ = typeof Field extends typeof FormField ? true : never`) or remove the alias surface.",
        "reasoning": "",
        "summary_hash": "ad9cea8f"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-04-26T14:29:22+00:00",
      "last_seen": "2026-04-26T14:29:22+00:00",
      "resolved_at": null,
