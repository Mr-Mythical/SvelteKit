    "review::.::holistic::logic_clarity::sync_handlers_marked_async": {
      "id": "review::.::holistic::logic_clarity::sync_handlers_marked_async",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Five SvelteKit handlers/loads are marked async but contain no await, wrapping purely synchronous work in an unnecessary microtask",
      "detail": {
        "holistic": true,
        "dimension": "logic_clarity",
        "related_files": [
          "src/routes/sitemap.xml/+server.ts",
          "src/routes/api/calculate-runs/+server.ts",
          "src/routes/beta-raidtesting/+page.server.ts",
          "src/routes/raid/boss/+page.server.ts",
          "src/routes/raid/boss/[bossname]/+page.server.ts"
        ],
        "evidence": [
          "src/routes/sitemap.xml/+server.ts: `export const GET = async () => { ... new Response(sitemap, ...) }` \u2014 only string assembly, no await.",
          "src/routes/api/calculate-runs/+server.ts: `export const GET: RequestHandler = async ({ url }) => { ... }` \u2014 only parseInt, calculateKeystoneBreakdown, a for-sum, and apiOk; no await.",
          "src/routes/beta-raidtesting/+page.server.ts: `export const load: PageServerLoad = async () => { throw redirect(308, '/raid'); };` \u2014 single sync throw.",
          "src/routes/raid/boss/+page.server.ts: same pattern (`async () => { throw redirect(307, ...) }`).",
          "src/routes/raid/boss/[bossname]/+page.server.ts: `async ({ params }) => { const boss = bosses.find(...); if (!boss) throw redirect(...); return { bossId, boss } }` \u2014 no await."
        ],
        "suggestion": "Drop the `async` keyword on these handlers/loads. SvelteKit's RequestHandler and PageServerLoad both accept `MaybePromise<...>`, so a sync function is type-correct and removes the cosmetic Promise wrapper, making it obvious at the signature level that the handler does no I/O.",
        "reasoning": "",
        "summary_hash": "ee9923f8"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-04-26T23:18:27+00:00",
      "last_seen": "2026-04-26T23:18:27+00:00",
      "resolved_at": null,
