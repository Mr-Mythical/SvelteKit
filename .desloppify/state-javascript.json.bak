    "review::.::holistic::high_level_elegance::db_index_conflates_databases": {
      "id": "review::.::holistic::high_level_elegance::db_index_conflates_databases",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "src/lib/db/index.ts barrel-exports user-DB modules, conflating the documented two-database boundary",
      "detail": {
        "holistic": true,
        "dimension": "high_level_elegance",
        "related_files": [
          "src/lib/db/index.ts"
        ],
        "evidence": [
          "userSchema.ts opens with a doc comment carefully separating raidSchema (DATABASE_URL, getRaidDb) from userSchema (DATABASE_USER_URL, getUserDb) \u2014 'one of two intentionally separate databases'.",
          "index.ts then collapses both into one entry point: `export * from './userSchema'; export * from './users'; export * from './userRecents'; export { getUserDb } from './userDb';` while also defining and exporting getRaidDb itself.",
          "The result: a single $lib/db import surface for two databases the rest of the architecture treats as deliberately separate. Any consumer doing `import { getRaidDb, getUserDb, users } from '$lib/db'` undermines the boundary the schema files describe."
        ],
        "suggestion": "Make db/index.ts the raid-DB entry only (define/export getRaidDb and re-export schema.ts), and make consumers import user-DB things from a sibling barrel like '$lib/db/user' (which would re-export userSchema, users, userRecents, getUserDb). Mirrors the dual-config split (drizzle.config.ts vs drizzle.user.config.ts) at the import level.",
        "reasoning": "",
        "summary_hash": "ce351f43"
      },
      "status": "fixed",
      "note": "not reported in latest holistic re-import",
