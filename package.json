{
	"name": "sveltekit",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"cloudflare": "npm run build && npm run wrangler",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"wrangler": "wrangler pages dev .svelte-kit/cloudflare",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:user:generate": "drizzle-kit generate --config=drizzle.user.config.ts",
		"db:user:migrate": "drizzle-kit migrate --config=drizzle.user.config.ts",
		"db:user:push": "drizzle-kit push --config=drizzle.user.config.ts",
		"db:user:drop": "drizzle-kit drop --config=drizzle.user.config.ts",
		"cleanup:under90-recents": "node scripts/cleanup-under90-recents.mjs"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250109.0",
		"@eslint/js": "^10.0.1",
		"@lucide/svelte": "^1.9.0",
		"@sveltejs/adapter-cloudflare": "^7.0.1",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/jest-dom": "^6.6.4",
		"@testing-library/svelte": "^5.2.8",
		"@testing-library/user-event": "^14.6.1",
		"@types/better-sqlite3": "^7.6.12",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/ui": "^4.1.5",
		"bits-ui": "^2.18.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"formsnap": "^2.0.1",
		"globals": "^16.5.0",
		"jiti": "^2.6.1",
		"jsdom": "^29.0.2",
		"mode-watcher": "^1.1.0",
		"prettier": "~3.4.2",
		"prettier-plugin-svelte": "^3.2.6",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"svelte": "^5.0.0",
		"svelte-chartjs": "^4.0.1",
		"svelte-check": "^4.0.0",
		"svelte-sonner": "^1.1.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4",
		"tslib": "^2.4.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^7.3.2",
		"vitest": "^4.1.5"
	},
	"type": "module",
	"dependencies": {
		"@auth/core": "^0.41.1",
		"@auth/drizzle-adapter": "^1.11.1",
		"@auth/sveltekit": "^1.11.1",
		"chart.js": "^4.4.7",
		"chartjs-plugin-annotation": "^3.1.0",
		"chartjs-plugin-zoom": "^2.2.0",
		"clsx": "^2.1.0",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.5",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"engines": {
		"node": ">=20.0.0",
		"npm": ">=9.0.0"
	}
}
